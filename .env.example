# Canonical Agent_stock environment template

# Stocks
STOCK_LIST=600519,300750,002594

# Data sources
TUSHARE_TOKEN=

# LLMs
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_REQUEST_DELAY=2.0
GEMINI_MAX_RETRIES=5
GEMINI_RETRY_DELAY=5.0

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_TEMPERATURE=0.7
# ANTHROPIC_MAX_TOKENS=8192

# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.7

# Search providers
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=
BOCHA_API_KEYS=
NEWS_MAX_AGE_DAYS=3
BIAS_THRESHOLD=5.0

# Persistence
DATABASE_PATH=./data/stock_analysis.db
# DATABASE_URL=postgresql+psycopg://user:password@127.0.0.1:5432/agent_stock
SAVE_CONTEXT_SNAPSHOT=true

# Realtime data controls
ENABLE_REALTIME_QUOTE=true
ENABLE_CHIP_DISTRIBUTION=true
ENABLE_EASTMONEY_PATCH=false
REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# CLI / agent runtime
AGENT_RUN_MODE=once
AGENT_POLL_INTERVAL_MINUTES=5
AGENT_MARKET_TIMEZONE=Asia/Shanghai
AGENT_MARKET_SESSIONS=09:30-11:30,13:00-15:00
AGENT_AI_REFRESH_POLICY=daily_once

AGENT_ACCOUNT_NAME=paper-default
AGENT_INITIAL_CASH=1000000
AGENT_MAX_SINGLE_POSITION_PCT=0.50
AGENT_MAX_TOTAL_EXPOSURE_PCT=0.90
AGENT_FEE_RATE=0.0003
AGENT_SELL_TAX_RATE=0.001
AGENT_SLIPPAGE_BPS=5
AGENT_MIN_TRADE_LOT=100

AGENT_WEIGHT_STRONG_BUY=0.50
AGENT_WEIGHT_BUY=0.30
AGENT_WEIGHT_HOLD=0.20
AGENT_WEIGHT_WAIT=0.00
AGENT_WEIGHT_SELL=0.00

# Service mode
AGENT_SERVICE_MODE=false
AGENT_SERVICE_HOST=0.0.0.0
AGENT_SERVICE_PORT=8001
AGENT_SERVICE_AUTH_TOKEN=
AGENT_TASK_MAX_WORKERS=3
AGENT_WRITE_LOCAL_REPORTS=false
AGENT_LLM_REQUEST_TIMEOUT_MS=120000

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO

# Optional proxy support; NO_PROXY for common domestic data sources is auto-expanded.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
